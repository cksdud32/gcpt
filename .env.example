# ─── AI API Keys ─────────────────────────────────────────────────────────────
# API 키를 설정하지 않으면 Mock mode로 실행됩니다 (실제 API 호출 없음)

# OpenAI — GPT 실제 응답에 필요
OPENAI_API_KEY=

# Google Gemini — Gemini 실제 응답에 필요
GEMINI_API_KEY=

# Anthropic Claude — 현재 미사용 (향후 확장용)
ANTHROPIC_API_KEY=

# ─── Model Settings ───────────────────────────────────────────────────────────
# 기본값으로 동작하므로 변경 불필요

GPT_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash
