{
  "name": "gcpt",
  "version": "0.1.0",
  "main": "out/main/index.cjs",
  "scripts": {
    "app": "electron-vite dev",
    "app:build": "electron-vite build",
    "dist:win": "electron-vite build && electron-builder --win --config electron-builder.config.cjs",
    "build": "tsc",
    "typecheck": "tsc && tsc -p tsconfig.renderer.json",
    "start": "node dist/simulation.js",
    "dev": "tsx src/simulation.ts",
    "run:real": "tsx src/run.ts",
    "run:stress": "tsx src/orchestration-sim.ts",
    "test": "tsx src/run-tests.ts",
    "test:mode": "tsx src/test-modes.ts",
    "prepublish:check": "npm run typecheck && npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^28.3.3",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "playwright-core": "^1.60.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "openai": "^6.41.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
